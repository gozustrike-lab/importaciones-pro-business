# ────────────────────────────────────────────────────────────
# ImportHub Perú — Variables de Entorno
# ────────────────────────────────────────────────────────────

# Database - Neon PostgreSQL (Pooled para runtime en Vercel serverless)
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Database - Neon PostgreSQL (Direct para migraciones Prisma)
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# NextAuth - URL de producción (sin barra final)
NEXTAUTH_URL="https://importaciones-pro-business.vercel.app"

# NextAuth - Secreto JWT (genera uno con: openssl rand -base64 32)
NEXTAUTH_SECRET="REEMPLAZA_CON_UN_SECRETO_SEGURO"

# Google OAuth (opcional — configura en Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# eBay API (opcional — configura en eBay Developer Program)
EBAY_APP_ID=""
EBAY_CERT_ID=""
EBAY_SANDBOX="false"
